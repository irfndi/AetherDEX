{
  "name": "@aetherdex/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsr generate && vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist --project-name aether-dex",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsgo --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/router-devtools": "^1.167.0",
    "@wagmi/core": "^3.5.5",
    "@reown/appkit": "^1.8.21",
    "@reown/appkit-adapter-wagmi": "^1.8.21",
    "daisyui": "^5.6.6",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.561.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.54.1",
    "wagmi": "^3.6.21"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.61.1",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260629.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-istanbul": "4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "happy-dom": "^16.8.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "7.0.1-rc",
    "vite": "^7.3.6",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=24.0.0"
  }
}
