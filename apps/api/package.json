{
  "name": "@aetherdex/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8080",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "d1:create": "wrangler d1 create aetherdex-main",
    "d1:migrate:local": "wrangler d1 migrations apply aetherdex-main --local",
    "d1:migrate:remote": "wrangler d1 migrations apply aetherdex-main --remote",
    "kv:create": "wrangler kv namespace create CACHE",
    "r2:create": "wrangler r2 bucket create aetherdex-storage",
    "secret:set": "wrangler secret put"
  },
  "dependencies": {
    "@aetherdex/shared": "workspace:*",
    "@effect/sql-d1": "4.0.0-beta.100",
    "@uniswap/v3-sdk": "^3.31.0",
    "@uniswap/v4-sdk": "^2.3.0",
    "effect": "4.0.0-beta.100",
    "hono": "^4.12.31",
    "siwe": "^3.0.0",
    "viem": "^2.55.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@cloudflare/vitest-pool-workers": "^0.18.7",
    "@effect/vitest": "4.0.0-beta.100",
    "@types/node": "^26.1.1",
    "@vitest/coverage-istanbul": "4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  },
  "engines": {
    "bun": ">=1.4.0",
    "node": ">=24.0.0"
  }
}
